# Copy this file to .env.deploy, fill in real secrets, DO NOT commit .env.deploy
DEBUG=False
# Generate one with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=replace-with-a-freshly-generated-secret-key
ALLOWED_HOSTS=your-app.up.railway.app
CSRF_TRUSTED_ORIGINS=https://your-app.up.railway.app

# Railway provides this automatically when a Postgres plugin is attached.
# Reference it in the service as: ${{Postgres.DATABASE_URL}}
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DBNAME
